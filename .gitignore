# ===========================
# Rymind Project .gitignore
# ===========================

# ---------- IDE & Editors ----------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- Environment & Secrets ----------
.env
.env.*
*.env
.env.local
.env.development
.env.production
.credentials
*credentials.json*
*token.json*
*.pem
*.key
*.p8
*.p12
*.jks
*.keystore
*.mobileprovision
google-play-service-account.json

# ---------- Python ----------
__pycache__/
*.pyc
*.pyo
venv/
.venv/
*.egg-info/

# ---------- Build & Output ----------
/build
dist/
web-build/
.expo/
.metro-cache/
.metro-health-check*
*.tsbuildinfo
expo-env.d.ts
.kotlin/
*.orig.*

# ---------- Logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ---------- OS Files ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- Testing ----------
/coverage

# ---------- Archives ----------
*.zip
*.tar.gz
*.tar
*.tgz

# ---------- Deployment ----------
.vercel
.cache/

# ---------- Emergent Agent (CI platform) ----------
.emergent/
.gitconfig

# ---------- Test artifacts (CI-generated) ----------
test_reports/
test_result.md
backend_test.py
tests/

# ---------- Design docs (internal) ----------
design_guidelines.json

# ---------- Expo template leftovers ----------
app-example/
